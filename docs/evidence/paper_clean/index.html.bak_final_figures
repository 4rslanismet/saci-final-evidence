<script>
let rows = [];

function showPanel(id, btn) {
  document.querySelectorAll(".panel").forEach(p => p.classList.remove("active"));
  document.getElementById(id).classList.add("active");

  document.querySelectorAll(".tabs button").forEach(b => b.classList.remove("active"));
  btn.classList.add("active");
}

function dirFor(row) {
  if (row.stage_id === "S7A") return "S7A_critical_dc01_sysmon_loss";
  if (row.stage_id === "S7B") return "S7B_noncritical_ws01_sysmon_loss";
  return `${row.stage_id}_${row.stage_name}`;
}

function byId(id) {
  return rows.find(r => r.stage_id === id) || {};
}

function num(v) {
  const n = Number(v);
  return Number.isFinite(n) ? n : 0;
}

function setHtml(id, value) {
  const el = document.getElementById(id);
  if (el) el.innerHTML = value;
}

function renderScenario() {
  const sid = document.getElementById("scenarioSelect").value;
  const row = byId(sid);
  const dir = dirFor(row);

  setHtml("scenarioDetail", `
    <p><span class="badge">${row.stage_id}</span> <b>${row.stage_name}</b></p>
    <div class="kpis">
      <div class="kpi"><div class="label">SACI</div><div class="value">${row.SACI}</div></div>
      <div class="kpi"><div class="label">Missing edges</div><div class="value">${row.missing_edges}</div></div>
      <div class="kpi"><div class="label">Observed edges</div><div class="value">${row.observed_edges}</div></div>
      <div class="kpi"><div class="label">Total edges</div><div class="value">${row.edges}</div></div>
    </div>
    <p><b>Type:</b> ${row.scenario_type}</p>
    <p><b>Description:</b> ${row.description || "-"}</p>
    <p><b>Components:</b> LC=${row.LC}, CAC=${row.CAC}, MDC=${row.MDC}, CTIC=${row.CTIC}, TF=${row.TF}</p>
    <p>
      <a href="../graph.html?stage=${encodeURIComponent(dir)}" target="_blank">Full interactive graph</a>
      |
      <a href="../data/${dir}/saci_llm_explanation.md" target="_blank">Policy-guided explanation</a>
      |
      <a href="../data/${dir}/saci_graph_summary.md" target="_blank">Graph summary</a>
    </p>
    <pre>${JSON.stringify(row, null, 2)}</pre>
  `);
}

function renderMatrix() {
  const ids = ["S9","S10","S11","S12","S13","S14","S15","S16","S17","S18"];
  const matrix = document.getElementById("fault-matrix");
  matrix.innerHTML = "";

  ids.forEach(id => {
    const r = byId(id);
    const cls = id === "S17" || id === "S18"
      ? "green"
      : (id === "S12" || id === "S13"
      ? "purple"
      : (id === "S15" ? "yellow" : "orange"));

    const div = document.createElement("div");
    div.className = `node ${cls}`;
    div.innerHTML = `<b>${id}</b><br>${r.stage_name || ""}<br>SACI=${r.SACI || "-"}<br>missing=${r.missing_edges || "-"}`;
    matrix.appendChild(div);
  });
}

function renderTable() {
  const tbody = document.querySelector("#fullTable tbody");
  tbody.innerHTML = "";

  rows.forEach(row => {
    const dir = dirFor(row);
    const tr = document.createElement("tr");

    tr.innerHTML = `
      <td>${row.stage_id}</td>
      <td>${row.stage_name}</td>
      <td>${row.scenario_type}</td>
      <td>${row.LC}</td>
      <td>${row.CAC}</td>
      <td>${row.MDC}</td>
      <td>${row.CTIC}</td>
      <td>${row.TF}</td>
      <td><b>${row.SACI}</b></td>
      <td>${row.observed_edges}</td>
      <td>${row.missing_edges}</td>
      <td><a href="../graph.html?stage=${encodeURIComponent(dir)}" target="_blank">graph</a></td>
    `;

    tbody.appendChild(tr);
  });
}

async function load() {
  rows = await fetch("data/progression.json").then(r => r.json());

  const s8 = byId("S8");
  const s7a = byId("S7A");
  const s7b = byId("S7B");

  setHtml("k-scenarios", rows.length);
  setHtml("k-s8", s8.SACI || "-");
  setHtml("k-missing", s8.missing_edges || "-");

  setHtml("closure-result", `S8 final closure<br>SACI=${s8.SACI}<br>missing=${s8.missing_edges}`);

  setHtml("crit-s7a", `S7A<br>Critical DC01 Sysmon loss<br>SACI=${s7a.SACI}<br>missing=${s7a.missing_edges}`);
  setHtml("crit-impact-a", `Impact<br>critical telemetry loss<br>strong score regression`);

  setHtml("crit-s7b", `S7B<br>Non-critical WS01 Sysmon loss<br>SACI=${s7b.SACI}<br>missing=${s7b.missing_edges}`);
  setHtml("crit-impact-b", `Impact<br>non-critical telemetry loss<br>smaller score regression`);

  const dropA = Math.max(0, 100 - num(s7a.SACI));
  const dropB = Math.max(0, 100 - num(s7b.SACI));

  document.getElementById("bar-s7a").style.width = `${Math.min(100, dropA * 3)}%`;
  document.getElementById("bar-s7b").style.width = `${Math.min(100, dropB * 3)}%`;

  setHtml("drop-s7a", dropA.toFixed(2));
  setHtml("drop-s7b", dropB.toFixed(2));

  setHtml("missing-impact", `Score impact<br>SACI=${s7a.SACI}<br>missing=${s7a.missing_edges}`);
  setHtml("tax-total", rows.length);

  const select = document.getElementById("scenarioSelect");
  rows.forEach(r => {
    const opt = document.createElement("option");
    opt.value = r.stage_id;
    opt.textContent = `${r.stage_id} - ${r.stage_name}`;
    select.appendChild(opt);
  });

  select.value = "S8";

  renderScenario();
  renderMatrix();
  renderTable();
}

load();
</script>


