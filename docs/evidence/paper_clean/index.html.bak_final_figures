    line-height: 1.1;
  }

  .fm-note {
    margin-top: 20px;
    border-left: 5px solid #2563eb;
    background: #f8fafc;
    border-radius: 12px;
    padding: 14px 16px;
    color: #0f172a;
    font-weight: 700;
    line-height: 1.5;
  }

  @media (max-width: 760px) {
    .faultMatrixSection {
      padding: 16px !important;
    }

    .fm-grid {
      grid-template-columns: 1fr;
    }

    .fm-card {
      min-height: auto;
    }
  }
</style>


