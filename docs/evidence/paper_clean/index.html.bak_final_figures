<!doctype html>
<html lang="tr">
<head>
<meta charset="utf-8">
<title>SACI Paper Clean View</title>
<style>
:root {
  --bg: #0f172a;
  --panel: #111827;
  --panel2: #1f2937;
  --line: #334155;
  --text: #e5e7eb;
  --muted: #94a3b8;

  --blue: #dbeafe;
  --orange: #ffedd5;
  --green: #dcfce7;
  --red: #fee2e2;
  --purple: #f3e8ff;
  --yellow: #fef9c3;
  --cyan: #ccfbf1;
  --gray: #e5e7eb;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  background: var(--bg);
  color: var(--text);
  font-family: Arial, sans-serif;
}

header {
  padding: 22px 28px;
  background: #020617;
  border-bottom: 1px solid var(--line);
}

header h1 {
  margin: 0 0 6px 0;
}

header p {
  margin: 0;
  color: var(--muted);
}

main {
  padding: 22px;
}

.card {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 18px;
  margin-bottom: 18px;
}

.kpis {
  display: grid;
  grid-template-columns: repeat(4, minmax(180px, 1fr));
  gap: 12px;
}

.kpi {
  background: var(--panel2);
  border: 1px solid var(--line);
  border-radius: 12px;
  padding: 14px;
}

.kpi .label {
  color: var(--muted);
  font-size: 13px;
}

.kpi .value {
  font-size: 30px;
  font-weight: 800;
  margin-top: 4px;
}

.tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tabs button,
select {
  background: var(--panel2);
  color: var(--text);
  border: 1px solid var(--line);
  border-radius: 10px;
  padding: 10px 13px;
  cursor: pointer;
}

.tabs button.active {
  background: #2563eb;
  border-color: #60a5fa;
}

.panel {
  display: none;
}

.panel.active {
  display: block;
}

.paper {
  background: white;
  color: #0f172a;
  border-radius: 14px;
  padding: 34px;
  border: 1px solid #cbd5e1;
  overflow-x: auto;
}

.paper h2 {
  text-align: center;
  margin: 0 0 28px 0;
  font-size: 28px;
}

.flow {
  display: grid;
  grid-template-columns: repeat(4, minmax(180px, 1fr));
  gap: 18px;
  margin-bottom: 18px;
}

.flow-5 {
  display: grid;
  grid-template-columns: repeat(5, minmax(150px, 1fr));
  gap: 16px;
  margin-bottom: 18px;
}

.flow-3 {
  display: grid;
  grid-template-columns: repeat(3, minmax(220px, 1fr));
  gap: 18px;
  margin-bottom: 18px;
}

.node {
  min-height: 105px;
  border: 2px solid #334155;
  border-radius: 16px;
  padding: 16px;
  text-align: center;
  line-height: 1.35;
  font-size: 16px;
  font-weight: 650;
  display: flex;
  align-items: center;
  justify-content: center;
  word-break: normal;
  overflow-wrap: anywhere;
}

.node.small {
  min-height: 86px;
  font-size: 14px;
}

.node.big {
  min-height: 125px;
  font-size: 18px;
}

.blue { background: var(--blue); }
.orange { background: var(--orange); }
.green { background: var(--green); }
.red { background: var(--red); }
.purple { background: var(--purple); }
.yellow { background: var(--yellow); }
.cyan { background: var(--cyan); }
.gray { background: var(--gray); }

.arrow-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
  margin: -6px 0 18px 0;
  color: #475569;
  font-size: 13px;
  font-weight: 700;
  text-align: center;
}

.note {
  margin-top: 22px;
  padding: 14px 16px;
  background: #f8fafc;
  border-left: 5px solid #2563eb;
  font-size: 16px;
  font-weight: 650;
}

.note.warn {
  border-left-color: #dc2626;
}

.compare {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22px;
}

.compare-card {
  border: 2px solid #334155;
  border-radius: 16px;
  padding: 18px;
}

.bars {
  margin-top: 24px;
}

.bar-row {
  display: grid;
  grid-template-columns: 120px 1fr 80px;
  gap: 12px;
  align-items: center;
  margin-bottom: 12px;
}

.bar-bg {
  height: 26px;
  background: #e5e7eb;
  border-radius: 999px;
  overflow: hidden;
}

.bar-red {
  height: 100%;
  background: #ef4444;
}

.bar-orange {
  height: 100%;
  background: #f97316;
}

.matrix {
  display: grid;
  grid-template-columns: repeat(5, minmax(170px, 1fr));
  gap: 14px;
}

.matrix .node {
  min-height: 125px;
  font-size: 14px;
}

.scenario-detail {
  background: var(--panel2);
  border: 1px solid var(--line);
  border-radius: 12px;
  padding: 14px;
}

.badge {
  display: inline-block;
  padding: 4px 8px;
  border-radius: 999px;
  background: #1e3a8a;
  color: #bfdbfe;
  font-size: 12px;
  font-weight: 700;
}

table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}

th, td {
  padding: 8px 9px;
  border-bottom: 1px solid var(--line);
}

th {
  color: #bfdbfe;
  text-align: left;
}

a {
  color: #93c5fd;
}

pre {
  background: #020617;
  color: #e5e7eb;
  padding: 14px;
  border-radius: 10px;
  overflow: auto;
  white-space: pre-wrap;
}

@media print {
  body {
    background: white;
  }

  header,
  .tabs,
  .nonprint {
    display: none;
  }

  .panel {
    display: block !important;
    page-break-after: always;
  }

  .card {
    border: none;
    padding: 0;
  }
}
</style>

