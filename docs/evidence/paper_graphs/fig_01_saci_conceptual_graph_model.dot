digraph G {
rankdir=LR;
graph [splines=ortho, ranksep=0.8, nodesep=0.45, bgcolor="white", label="SACI Conceptual Graph Model", labelloc=t, fontsize=20, fontname="Arial"];
node [fontsize=11, margin=0.12];
edge [fontsize=9, arrowsize=0.7];
"assets" [label="Assets
DC / endpoint / firewall", shape=box, style="rounded,filled", fillcolor="#dbeafe", color="#334155", fontname="Arial"];
"logsources" [label="Log sources
Security / Sysmon / PowerShell / authlog / firewall", shape=box, style="rounded,filled", fillcolor="#ffedd5", color="#334155", fontname="Arial"];
"controls" [label="Detection controls
Expected visibility rules", shape=box, style="rounded,filled", fillcolor="#dcfce7", color="#334155", fontname="Arial"];
"rules" [label="Wazuh rules
Observed alerts", shape=box, style="rounded,filled", fillcolor="#fee2e2", color="#334155", fontname="Arial"];
"mitre" [label="MITRE ATT&CK
Techniques", shape=box, style="rounded,filled", fillcolor="#f3e8ff", color="#334155", fontname="Arial"];
"cti" [label="CTI / MISP
IOC enrichment", shape=box, style="rounded,filled", fillcolor="#ccfbf1", color="#334155", fontname="Arial"];
"metrics" [label="SACI metrics
LC / CAC / MDC / CTIC / TF", shape=box, style="rounded,filled", fillcolor="#fef9c3", color="#334155", fontname="Arial"];
"score" [label="SACI score
Deterministic visibility score", shape=oval, style="rounded,filled", fillcolor="#e0f2fe", color="#334155", fontname="Arial"];
"assets" -> "logsources" [label="emits", color="#475569", fontcolor="#475569", style="solid", penwidth="1.4", fontname="Arial"];
"logsources" -> "rules" [label="collected by Wazuh", color="#475569", fontcolor="#475569", style="solid", penwidth="1.4", fontname="Arial"];
"assets" -> "controls" [label="protected by", color="#475569", fontcolor="#475569", style="solid", penwidth="1.4", fontname="Arial"];
"controls" -> "logsources" [label="uses log source", color="#475569", fontcolor="#475569", style="solid", penwidth="1.4", fontname="Arial"];
"controls" -> "rules" [label="produces rule", color="#475569", fontcolor="#475569", style="solid", penwidth="1.4", fontname="Arial"];
"controls" -> "mitre" [label="detects technique", color="#475569", fontcolor="#475569", style="solid", penwidth="1.4", fontname="Arial"];
"cti" -> "rules" [label="IOC converted to alert", color="#475569", fontcolor="#475569", style="solid", penwidth="1.4", fontname="Arial"];
"rules" -> "metrics" [label="evidence", color="#475569", fontcolor="#475569", style="solid", penwidth="1.4", fontname="Arial"];
"mitre" -> "metrics" [label="coverage", color="#475569", fontcolor="#475569", style="solid", penwidth="1.4", fontname="Arial"];
"cti" -> "metrics" [label="CTI closure", color="#475569", fontcolor="#475569", style="solid", penwidth="1.4", fontname="Arial"];
"metrics" -> "score" [label="weighted formula", color="#475569", fontcolor="#475569", style="solid", penwidth="1.4", fontname="Arial"];
}
